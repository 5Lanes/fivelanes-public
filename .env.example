# --- Required ---
SOURCE_ACCOUNT=you+fivelanes@example.com
SOURCE_OAUTH_ACCOUNT_ID=work
OWNER_NAME=Your Name

# Optional comma-separated Gmail addresses that route to you (same inbox plumbing).
# OWNER_EMAIL_ALIASES=you@example.com,alias@example.com

# --- LLM backend ---
# FIVELANES_BACKEND=llama
# CLAUDE_API_KEY=

# Ollama (when FIVELANES_BACKEND=llama)
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_HOST_USERNAME=
# OLLAMA_HOST_PASSWORD=
# OLLAMA_MODEL_SEGMENTATION=llama3.2:3b
# OLLAMA_MODEL_SUMMARY=llama3.1:8b
# OLLAMA_MODEL_FIVELANES_SUMMARY=llama3.1:8b
# OLLAMA_MODEL_EMAIL_REPLY=llama3.1:8b
# OLLAMA_MODEL_IMAGE_DESCRIPTION=llava:7b

# --- Paths (private layer on top of OS repo) ---
# FIVELANES_INFRA_ROOT=/path/to/fivelanes-os
# FIVELANES_DATA_ROOT=/path/to/your/fivelanes-data
# FIVELANES_PROMPTS_PATH=/path/to/your/services/prompts.json
# TEXTS_CONVERSATIONS_DIR=conversations
# DATABASE_NAME=timeline.db

# --- Dashboard ---
# DASHBOARD_HOST=0.0.0.0
# DASHBOARD_PORT=8000

# --- Scheduler ---
# FIVELANES_INTERVAL_SEC=900
# FIVELANES_LOOKBACK_DAYS=14
# FIVELANES_QUIET_START_HOUR=0
# FIVELANES_QUIET_END_HOUR=6
# FIVELANES_SCHEDULER_TZ=America/New_York
# CALENDAR_AVAILABILITY_DISABLE=0
# CALENDAR_AVAILABILITY_WEEKS=4
# SCHEDULING_AVAILABILITY_STEP_DISABLE=0

# --- Logging ---
# FIVELANES_LOG_LEVEL=INFO
# FIVELANES_LOG_DIR=logs
# FIVELANES_LOG_FILE=fivelanes.log
