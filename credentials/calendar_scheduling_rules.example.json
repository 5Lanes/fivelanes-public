{
  "schema_version": 1,
  "calendar_source": {
    "_description": "Use connected Google OAuth accounts; pull appointments from every calendar on those accounts.",
    "provider": "google_calendar",
    "accounts": "all_connected",
    "include_calendars": "all_subscribed",
    "treat_each_event_as": "busy_interval_after_buffers_applied"
  },
  "timezone": "America/New_York",
  "meeting_buffers_minutes": {
    "in_person": {
      "before": 60,
      "after": 60
    },
    "virtual": {
      "before": 30,
      "after": 30
    },
    "virtual_detection": {
      "location_substrings_case_insensitive": [
        "zoom.us",
        "teams.microsoft",
        "meet.google",
        "google meet",
        "webex",
        "http://",
        "https://"
      ],
      "title_substrings_case_insensitive": [
        "zoom:",
        "google meet",
        "teams meeting",
        "webex"
      ],
      "treat_as_virtual_if": [
        "Google Calendar event has conferenceData (Meet link) and no separate physical address in location",
        "location is empty or whitespace-only"
      ]
    }
  },
  "scheduling_window_local": {
    "weekdays": ["MO", "TU", "WE", "TH", "FR"],
    "from_local": "09:00",
    "to_local": "18:00",
    "per_weekday": {}
  },
  "parenting_blocks": {
    "_description": "Optional recurring unavailable windows. Remove this section if not needed.",
    "school_day_parenting": {
      "before_school_unavailable_from_local": "08:00",
      "before_school_unavailable_until_local": "09:00",
      "after_school_unavailable_from_local": "15:00",
      "after_school_unavailable_until_local": "18:00"
    },
    "alternating_week_anchor": {
      "anchor_date_iso": "2026-01-01",
      "anchor_has_thursday_morning": true,
      "wednesday_afternoon_same_parity_as_thursday_morning": true
    },
    "recurring_occupied": []
  },
  "availability_include_calendars": [
    {
      "account_id": "work",
      "calendar_id": "you@example.com"
    }
  ]
}
